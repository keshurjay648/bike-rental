PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bike_rental
CORS_ORIGIN=http://127.0.0.1:5500
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin access — comma-separated emails that can open /admin.html
ADMIN_EMAILS=admin@example.com

# Firebase Configuration (for OTP verification)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# SMS Configuration (optional - for phone OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
